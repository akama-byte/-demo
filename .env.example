# Gemini API Key (optional but recommended)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Notification (optional; if omitted prints to stdout)
SLACK_WEBHOOK_URL=

# Screening params
TOP_N=10
MIN_PRICE=200
MIN_MARKET_CAP=20000000000
MIN_VOLUME_RATIO=1.2

# IANA timezone
APP_TIMEZONE=Asia/Tokyo

# Symbol list path (optional override)
# SYMBOLS_FILE=./config/symbols.txt
